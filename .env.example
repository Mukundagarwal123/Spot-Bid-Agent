# App
APP_ENV=local
APP_NAME=spot-bid-agent
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/spotbid

# Redis / Queue
REDIS_URL=redis://localhost:6379/0

# Turvo
TURVO_WEBHOOK_SECRET=replace_me

# Turvo internal DB (for covered_loads carrier recommendation)
TURVO_DB_URL=postgresql+psycopg://user:pass@turvo-db-host:5432/turvo

# Local carrier contact cache used before Turvo fallback
CARRIER_DATA_CSV_PATH=C:/path/to/Carrire Data.csv

# Turvo API (for carrier email enrichment)
TURVO_API_BASE_URL=https://app.turvo.com
TURVO_API_CLIENT_ID=replace_me
TURVO_API_CLIENT_SECRET=replace_me

# Set to true in local dev to return mock carrier + email data (no real Turvo credentials needed)
TURVO_MOCK_CARRIERS=false

# DAT Parser LLM (OpenAI-compatible API)
LLM_BASE_URL=https://api.theagentic.ai/v1
LLM_MODEL=agentic-large
LLM_API_KEY=replace_me

# Resend
RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=ops@yourdomain.com
RESEND_WEBHOOK_SECRET=replace_me

# Meta WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_APP_SECRET=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
# JSON array of approved outbound templates shown in campaign setup.
WHATSAPP_TEMPLATES_JSON=[{"name":"spot_bid_opportunity","language":"en_US","label":"Spot Bid Opportunity","preview":"We have a spot freight opportunity matching your operating area. Reply with availability and your best all-in rate."}]

# Grafana Cloud Logs (Loki) - Free tier supported
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=replace_me
GRAFANA_CLOUD_LOKI_API_KEY=replace_me

# OpenTelemetry (optional, recommended)
OTEL_SERVICE_NAME=spot-bid-agent
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic base64_instanceid_apikey

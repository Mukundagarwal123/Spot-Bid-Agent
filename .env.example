# App
APP_ENV=local
APP_NAME=spot-bid-agent
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/spotbid

# Redis / Queue
REDIS_URL=redis://localhost:6379/0

# Turvo
TURVO_WEBHOOK_SECRET=replace_me

# Resend
RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=ops@yourdomain.com
RESEND_WEBHOOK_SECRET=replace_me

# Twilio
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_SMS_FROM=+15551234567
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567
TWILIO_WEBHOOK_SECRET=replace_me

# Grafana Cloud Logs (Loki) - Free tier supported
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=replace_me
GRAFANA_CLOUD_LOKI_API_KEY=replace_me

# OpenTelemetry (optional, recommended)
OTEL_SERVICE_NAME=spot-bid-agent
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic base64_instanceid_apikey
